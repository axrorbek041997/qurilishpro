NODE_ENV=development
PORT=3000

# MongoDB (matches docker-compose service name)
MONGODB_URI=mongodb://mongo:27017/qurilishpro

# Redis (matches docker-compose service name)
REDIS_URL=redis://redis:6379

# JWT secrets — change these in production!
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Uploads directory (relative to api root)
FILES_DIR=uploads
